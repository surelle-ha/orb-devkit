<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!--
    Allow cleartext traffic (ws://) for LAN daemon communication.
    Android does NOT support CIDR notation (192.168.0.0/16) in domain-config,
    so those entries were silently ignored, blocking all ws:// traffic.
    We use base-config to permit cleartext globally — safe because the daemon
    uses token-based auth and the app only connects on the local LAN.
  -->
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>